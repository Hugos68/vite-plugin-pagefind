    "package-manager-detector": "^1.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.31.0"
  },
  "packageManager": "pnpm@10.31.0"
