{
  "name": "vite-plugin-pagefind",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hugos68/vite-plugin-pagefind.git"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
